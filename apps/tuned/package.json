{
    "name": "@df-comparison/tuned",
    "version": "1.0.0",
    "private": true,
    "description": "Tuned Durable Function app with optimized configuration",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc && esbuild dist/src/index.js --bundle --platform=node --target=node22 --outfile=dist/index.js --external:@azure/functions-core",
